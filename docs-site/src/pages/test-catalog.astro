---
// The MDX lives in _test-catalog.mdx (underscore = not routed) and is wrapped
// here, so the layout receives frontmatter explicitly — same pattern as
// testing.astro wrapping _testing.mdx and index.astro wrapping _overview.mdx.
import type { ComponentProps } from "astro/types";
import Doc from "../layouts/Doc.astro";
import TestCatalog, { frontmatter } from "./_test-catalog.mdx";

const fm = frontmatter as ComponentProps<typeof Doc>["frontmatter"];
---
<Doc frontmatter={fm}>
  <TestCatalog />
</Doc>
