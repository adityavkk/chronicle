---
// The MDX lives in _horizontal-scale.mdx (underscore = not routed) and is
// wrapped here, so the layout receives frontmatter explicitly — same pattern as
// subscriptions.astro wrapping _subscriptions.mdx.
import type { ComponentProps } from "astro/types";
import Doc from "../layouts/Doc.astro";
import HorizontalScale, { frontmatter } from "./_horizontal-scale.mdx";

const fm = frontmatter as ComponentProps<typeof Doc>["frontmatter"];
---
<Doc frontmatter={fm}>
  <HorizontalScale />
</Doc>
