---
// SeqDiagram.astro — a lifeline sequence diagram for one request's path
// through Chronicle: Client → Handler (Go) → Store (Go) → Redis, and back.
//
// Data-driven and self-contained (like OpMap): pass `actors` (the lifeline
// labels, left to right) and `steps`. Each step is either a MESSAGE between
// two lifelines or a SELF action on one. Rendered to static markup at build
// time — no client JS, so it prints and degrades cleanly. Lifelines are drawn
// as dashed verticals behind the beats; a beat's arrow spans the grid columns
// between its two actors, with the arrowhead on the destination side.
//
// Indices are 0-based into `actors`. Column 1 of the grid is the step-number
// gutter, so actor k sits in grid column k + 2.

type Kind = "req" | "eval" | "self" | "reply" | "pub" | "wait";
type Step =
  | { from: number; to: number; label: string; loc?: string; kind?: Kind }
  | { on: number; label: string; loc?: string; kind?: Kind };

interface Props {
  /** Lifeline labels, left → right. Typically Client · Handler · Store · Redis. */
  actors: string[];
  /** Ordered beats. `from`/`to` = a message; `on` = a self action. */
  steps: Step[];
  /** Mono micro-label in the figure header. */
  label?: string;
  /** Optional caption below the diagram. Plain text or inline HTML. */
  caption?: string;
}
const { actors, steps, label = "Request lifecycle", caption } = Astro.props;
const n = actors.length;

// Center x of lifeline k as a calc() fraction of the post-gutter width.
const lifeLeft = (k: number) => `calc(28px + (100% - 28px) * ${((k + 0.5) / n).toFixed(5)})`;

function place(s: Step) {
  if ("on" in s) {
    return { self: true as const, col: s.on + 2, dir: "", kind: s.kind ?? "self" };
  }
  const lo = Math.min(s.from, s.to);
  const hi = Math.max(s.from, s.to);
  return {
    self: false as const,
    start: lo + 2,
    end: hi + 3, // grid-column end is exclusive
    dir: s.to > s.from ? "right" : "left",
    kind: s.kind ?? "req",
  };
}
---

<figure class="seqfig">
  <div class="seqfig-label mono">{label}</div>
  <div class="seq" style={`--n:${n}`}>
    <div class="seq-head">
      {actors.map((a, k) => (
        <div class="seq-actor mono" style={`grid-column:${k + 2}`}>{a}</div>
      ))}
    </div>
    <div class="seq-body">
      <div class="seq-lifelines" aria-hidden="true">
        {actors.map((_, k) => (
          <span class="seq-life" style={`left:${lifeLeft(k)}`}></span>
        ))}
      </div>
      <ol class="seq-steps">
        {steps.map((s, i) => {
          const p = place(s);
          return (
            <li class="seq-step">
              <span class="seq-n mono">{i + 1}</span>
              {p.self ? (
                <span class={`seq-self k-${p.kind}`} style={`grid-column:${p.col}`}>
                  <span class="seq-chip mono">
                    <span class="seq-loop" aria-hidden="true">↻</span>
                    <span set:html={s.label} />
                    {s.loc && <em class="seq-loc mono">{s.loc}</em>}
                  </span>
                </span>
              ) : (
                <span
                  class={`seq-msg dir-${p.dir} k-${p.kind}`}
                  style={`grid-column:${p.start}/${p.end}`}
                >
                  <span class="seq-label mono">
                    <span set:html={s.label} />
                    {s.loc && <em class="seq-loc mono">{s.loc}</em>}
                  </span>
                  <span class="seq-line" aria-hidden="true"></span>
                </span>
              )}
            </li>
          );
        })}
      </ol>
    </div>
  </div>
  {caption && (
    <figcaption class="seqfig-caption" set:html={caption} />
  )}
</figure>

<style lang="scss">
  .seqfig {
    margin: 32px 0 0 var(--rail-indent);
    max-width: var(--prose-max);
    background: var(--card);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .seqfig-label {
    padding: 14px 24px;
    border-bottom: 1px solid var(--rule);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .seqfig-caption {
    padding: 14px 24px 18px;
    border-top: 1px solid var(--rule);
    background: var(--paper);
    font-size: 13px;
    line-height: 1.5;
    color: var(--muted);
    :global(strong) { color: var(--ink); font-weight: 600; }
    :global(code) {
      font-family: var(--mono);
      font-size: 0.92em;
      background: var(--tint);
      padding: 1px 5px;
      border-radius: 3px;
      color: var(--accent-deep);
    }
  }

  // The diagram scrolls horizontally on narrow screens rather than crushing
  // four lifelines into nothing.
  .seq {
    padding: 8px 24px 18px;
    overflow-x: auto;
  }
  .seq-head,
  .seq-step {
    display: grid;
    grid-template-columns: 28px repeat(var(--n), minmax(96px, 1fr));
    align-items: center;
    min-width: 460px;
  }
  .seq-head {
    padding: 12px 0 14px;
    position: sticky;
    top: 0;
  }
  .seq-actor {
    text-align: center;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 5px 6px;
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    border-radius: 6px;
    margin: 0 6px;
  }

  .seq-body { position: relative; }
  .seq-lifelines {
    position: absolute;
    inset: 0;
    min-width: 460px;
    pointer-events: none;
  }
  .seq-life {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 0;
    border-left: 1px dashed var(--rule);
  }

  .seq-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 1;
  }
  .seq-step {
    position: relative;
    padding: 3px 0;
    min-height: 40px;
  }
  .seq-n {
    grid-column: 1;
    justify-self: start;
    align-self: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1px solid var(--rule);
    background: var(--card);
    color: var(--muted);
    font-size: 9.5px;
    display: grid;
    place-items: center;
  }

  // ── Messages (arrows between two lifelines) ──────────────────────────
  .seq-msg {
    align-self: center;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 4px 12px;
    min-width: 0;
  }
  .seq-label {
    font-size: 11px;
    line-height: 1.35;
    color: var(--ink);
    text-align: center;
    overflow-wrap: anywhere;
  }
  .seq-line {
    position: relative;
    height: 0;
    border-top: 1.5px solid var(--accent);
  }
  // Arrowheads: a small triangle on the destination end.
  .seq-msg.dir-right .seq-line::after,
  .seq-msg.dir-left .seq-line::before {
    content: "";
    position: absolute;
    top: 50%;
    width: 0;
    height: 0;
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
  }
  .seq-msg.dir-right .seq-line::after {
    right: 0;
    transform: translateY(-50%);
    border-left: 7px solid var(--accent);
  }
  .seq-msg.dir-left .seq-line::before {
    left: 0;
    transform: translateY(-50%);
    border-right: 7px solid var(--accent);
  }

  // Kind palette. req = accent (client/handler/store calls); eval = the
  // EVALSHA hop into Redis, emphasized; reply = the return path, muted green,
  // dashed; pub = a PUBLISH wakeup, warm; wait = blocking, italic grey.
  .seq-msg.k-eval .seq-label { color: var(--accent-deep); font-weight: 600; }
  .seq-msg.k-reply .seq-line { border-top-style: dashed; border-top-color: var(--ok); }
  .seq-msg.k-reply .seq-line::after { border-left-color: var(--ok); }
  .seq-msg.k-reply .seq-line::before { border-right-color: var(--ok); }
  .seq-msg.k-reply .seq-label { color: var(--ink-mute); }
  .seq-msg.k-pub .seq-line { border-top-color: var(--warn); }
  .seq-msg.k-pub .seq-line::after { border-left-color: var(--warn); }
  .seq-msg.k-pub .seq-line::before { border-right-color: var(--warn); }
  .seq-msg.k-pub .seq-label { color: var(--warn); }
  .seq-msg.k-wait .seq-line { border-top-style: dotted; border-top-color: var(--muted); }
  .seq-msg.k-wait .seq-line::after { border-left-color: var(--muted); }
  .seq-msg.k-wait .seq-line::before { border-right-color: var(--muted); }
  .seq-msg.k-wait .seq-label { color: var(--muted); font-style: italic; }

  // ── Self actions (a lifeline acting on itself) ───────────────────────
  .seq-self {
    align-self: center;
    display: flex;
    justify-content: center;
    padding: 2px 4px;
  }
  .seq-chip {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-size: 10.5px;
    line-height: 1.3;
    color: var(--accent-deep);
    background: var(--accent-tint);
    border: 1px solid rgba(36, 131, 123, 0.3);
    border-radius: 6px;
    padding: 5px 9px;
    text-align: left;
    max-width: 100%;
    overflow-wrap: anywhere;
  }
  .seq-self.k-wait .seq-chip {
    color: var(--muted);
    background: var(--tint);
    border-color: var(--rule);
    font-style: italic;
  }
  .seq-self.k-pub .seq-chip {
    color: var(--warn);
    background: rgba(173, 131, 1, 0.08);
    border-color: rgba(173, 131, 1, 0.3);
  }
  .seq-loop { font-style: normal; opacity: 0.7; }

  .seq-loc {
    margin-left: 7px;
    font-style: normal;
    font-size: 9.5px;
    color: var(--muted);
    white-space: nowrap;
  }

  @media (max-width: 840px) {
    .seqfig { margin-left: 0; max-width: none; }
  }
</style>
