---
// Site masthead: identity mark on the left, page links in the middle, source
// link on the right. The mark links home (useful on deep anchors); the page
// links move between the overview, the endpoint reference, and the
// subscriptions reference.
import Glyph from "./Glyph.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const home = `${base}/`;
const endpoints = `${base}/endpoints`;
const subscriptions = `${base}/subscriptions`;
const scaling = `${base}/horizontal-scale`;
const testing = `${base}/testing`;
const loadtesting = `${base}/load-testing`;
const wiki = `${base}/wiki`;
const REPO = "https://github.com/adityavkk/chronicle";

// Active page from the current path, normalized against the deployed base.
const rel = import.meta.env.BASE_URL
  ? Astro.url.pathname.replace(base, "").replace(/\/$/, "")
  : Astro.url.pathname.replace(/\/$/, "");
const onEndpoints = rel === "/endpoints";
const onSubscriptions = rel === "/subscriptions";
const onScaling = rel === "/horizontal-scale";
const onTesting = rel === "/testing";
const onLoadTesting = rel === "/load-testing";
const onWiki = rel === "/wiki" || rel.startsWith("/wiki/");
const onHome = rel === "" || rel === "/";
---
<nav class="masthead" aria-label="Site">
  <a class="mark" href={home} aria-label="Chronicle documentation — home">
    <Glyph />
    <span>CHRONICLE &middot; DOCS</span>
  </a>
  <div class="links">
    <a href={home} class:list={["link", { active: onHome }]} aria-current={onHome ? "page" : undefined}>Overview</a>
    <a href={endpoints} class:list={["link", { active: onEndpoints }]} aria-current={onEndpoints ? "page" : undefined}>Endpoints</a>
    <a href={subscriptions} class:list={["link", { active: onSubscriptions }]} aria-current={onSubscriptions ? "page" : undefined}>Subscriptions</a>
    <a href={scaling} class:list={["link", { active: onScaling }]} aria-current={onScaling ? "page" : undefined}>Scaling</a>
    <a href={testing} class:list={["link", { active: onTesting }]} aria-current={onTesting ? "page" : undefined}>Testing</a>
    <a href={loadtesting} class:list={["link", { active: onLoadTesting }]} aria-current={onLoadTesting ? "page" : undefined}>Load tests</a>
    <a href={wiki} class:list={["link", { active: onWiki }]} aria-current={onWiki ? "page" : undefined}>Wiki</a>
  </div>
  <a class="src" href={REPO}>
    <span>GitHub</span>
    <span class="arrow" aria-hidden="true">&nearr;</span>
  </a>
</nav>

<style lang="scss">
  // Aligns to the shell measure (--shell-max) with the shell's own 56px inline
  // padding (base.scss .shell), so the bar sits over the content column, not
  // the raw page edge. Static (not sticky): robust against the body grain
  // layer and print, with no z-index/backdrop to reason about.
  .masthead {
    max-width: var(--shell-max);
    margin: 0 auto;
    padding: 20px 56px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .masthead a { text-decoration: none; }

  .mark {
    display: inline-flex; align-items: center; gap: 10px;
    color: var(--accent);
    letter-spacing: 0.06em;
    transition: color 0.2s ease;
  }
  .mark:hover { color: var(--ink); }

  .links {
    display: inline-flex;
    align-items: center;
    gap: 22px;
  }
  .links .link {
    position: relative;
    color: var(--ink-mute);
    letter-spacing: 0.1em;
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }
  .links .link:hover { color: var(--ink); }
  .links .link.active { color: var(--accent); }
  .links .link.active::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -3px;
    height: 1.5px;
    background: var(--accent);
  }

  .src {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--accent);
    transition: color 0.2s ease;
  }
  .src .arrow { transition: transform 0.2s ease; }
  .src:hover { color: var(--ink); }
  .src:hover .arrow { transform: translate(2px, -2px); }

  // Match the shell's responsive inline padding (base.scss @media 840px),
  // so the bar tracks the content column at every width. The middle links
  // wrap under the mark on the narrowest screens.
  @media (max-width: 840px) {
    .masthead { padding: 16px 24px 0; flex-wrap: wrap; gap: 10px 16px; }
    .links { order: 3; width: 100%; gap: 18px; }
  }
  @media print { .masthead { display: none; } }
</style>
