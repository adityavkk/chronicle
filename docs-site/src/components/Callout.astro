---
// Tinted inline aside: the lightweight middle ground between plain prose and
// a heading. Slot accepts MDX content.
interface Props {
  /** Inline SVG glyph keyword. */
  icon?: "info" | "arrow" | "alert";
  /** Optional bold mono micro-label, e.g. "Note". */
  label?: string;
}
const { icon = "info", label } = Astro.props;

const paths: Record<NonNullable<Props["icon"]>, string> = {
  info: "M12 2a10 10 0 100 20 10 10 0 000-20zm0 5a1.3 1.3 0 110 2.6A1.3 1.3 0 0112 7zm1.2 10.5h-2.4v-6h2.4v6z",
  arrow: "M4 12h13.2l-5.1-5.1 1.4-1.4L21.4 12l-7.9 6.5-1.4-1.4 5.1-5.1H4z",
  alert: "M12 2L1 21h22L12 2zm0 6.2l6.9 11.6H5.1L12 8.2zM11 13h2v3.4h-2V13zm0 4.6h2v2h-2v-2z",
};
---

<aside class="callout">
  <svg class="ico" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d={paths[icon]} />
  </svg>
  <div class="body">
    {label && <span class="label">{label}</span>}
    <slot />
  </div>
</aside>

<style lang="scss">
  .callout {
    display: flex;
    gap: 14px;
    margin: 24px 0 0 var(--rail-indent);
    max-width: var(--prose-max);
    padding: 18px 22px;
    background: var(--accent-tint);
    border: 1.5px solid rgba(36, 131, 123, 0.35);
    border-radius: var(--radius);
    color: var(--ink);
    font-size: 15px;
    line-height: 1.55;
  }
  .ico {
    flex: 0 0 auto;
    width: 20px;
    height: 20px;
    margin-top: 2px;
    fill: var(--accent);
  }
  .body {
    min-width: 0;
    :global(p) { margin: 0; }
    :global(p + p) { margin-top: 10px; }
    :global(strong) { color: var(--accent-deep); font-weight: 600; }
    :global(em) { font-family: var(--serif-italic); font-style: italic; }
    :global(a) { color: var(--accent); }
    :global(code) {
      font-family: var(--mono);
      font-size: 0.9em;
      background: rgba(255, 254, 251, 0.7);
      padding: 1px 5px;
      border-radius: 3px;
      color: var(--accent-deep);
    }
  }
  .label {
    margin-right: 8px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
  @media (max-width: 840px) {
    .callout { margin-left: 0; }
  }
</style>
