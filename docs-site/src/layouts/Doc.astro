---
import "../styles/base.scss";
import "@fontsource-variable/inter";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/jetbrains-mono/600.css";
import "@fontsource/jetbrains-mono/700.css";
import Head from "../components/Head.astro";
import Masthead from "../components/Masthead.astro";
import Hero from "../components/Hero.astro";
import Glyph from "../components/Glyph.astro";

interface Props {
  /** Frontmatter passed from MDX */
  frontmatter: {
    title: string;
    /** One-line unfurl summary for <meta> description; falls back to deck. */
    summary?: string;
    eyebrow?: string;
    meta?: string;
    deck?: string;
    byline?: Array<{ label: string; value: string; href?: string }>;
  };
}
const { frontmatter: f } = Astro.props;
const metaDesc = f.summary ?? f.deck;

// Home href for the footer mark, built from BASE_URL so it resolves under the
// deployed base path (/chronicle) — a bare "/" would 404 on GitHub Pages.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const home = `${base}/`;
const REPO = "https://github.com/adityavkk/chronicle";
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={f.title} description={metaDesc} />
  </head>
  <body>
    <Masthead />
    <main class="shell">
      <Hero
        eyebrow={f.eyebrow}
        meta={f.meta}
        title={f.title}
        deck={f.deck}
        byline={f.byline}
      />

      <div class="doc-body">
        <slot />
      </div>

      <footer class="foot">
        <a class="mark" href={home} aria-label="Chronicle documentation — home">
          <Glyph />
          <span>CHRONICLE &middot; DURABLE STREAMS SERVER</span>
        </a>
        <div>
          <a href={REPO}>Source</a>
          {" · "}
          <a href={`${REPO}/blob/main/LICENSE`}>License</a>
        </div>
      </footer>
    </main>
  </body>
</html>

<style lang="scss">
  footer.foot {
    margin-top: 80px;
    padding: 36px 0 0;
    border-top: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.06em;
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 16px;
  }
  footer.foot a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.25s;
  }
  footer.foot a:hover { color: var(--ink); }
  .mark {
    display: inline-flex; align-items: center; gap: 10px;
  }
  @media print { footer.foot { display: none; } }
</style>
